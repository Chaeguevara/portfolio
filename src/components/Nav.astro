---
const base = import.meta.env.BASE_URL;
const href = (p: string) => `${base}${p.replace(/^\//, '')}`;
const { current = '' } = Astro.props as { current?: string };
const isActive = (path: string) => current === path;
---
<nav>
  <a class="nav-brand" href={href('')}>Portfolio</a>
  <div class="nav-links">
    <a
      href={href('')}
      class:list={[{ active: isActive('') }]}
      aria-current={isActive('') ? 'page' : undefined}
    >Home</a>
    <a
      href={href('works')}
      class:list={[{ active: isActive('works') }]}
      aria-current={isActive('works') ? 'page' : undefined}
    >Works</a>
    <a
      href={href('about')}
      class:list={[{ active: isActive('about') }]}
      aria-current={isActive('about') ? 'page' : undefined}
    >About</a>
    <a
      href={href('designer')}
      class:list={[{ active: isActive('designer') }]}
      aria-current={isActive('designer') ? 'page' : undefined}
    >Designer</a>
    <a
      href={href('study')}
      class:list={[{ active: isActive('study') }]}
      aria-current={isActive('study') ? 'page' : undefined}
    >Study</a>
    <div class="nav-dropdown">
      <button class="nav-dropdown-toggle" aria-label="In Progress">
        In Progress
      </button>
      <div class="nav-dropdown-content" id="in-progress-list"></div>
    </div>
    <button
      id="theme-toggle"
      class="theme-toggle"
      aria-label="Toggle Theme"
      style="background: none; border: none; cursor: pointer; color: var(--text-color); padding: 0 10px; font-size: 1.2rem;"
    >
      ◐
    </button>
  </div>
</nav>
