---
import Nav from '../components/Nav.astro';
import '../styles/main.scss';

interface Props {
  title?: string;
  current?: string;
}
const { title = 'Heejin Chae — Geometry, Folding & Code', current = '' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}vite.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script
      is:inline
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX"
      crossorigin="anonymous"
    ></script>
  </head>
  <body>
    <Nav current={current} />
    <div id="app">
      <slot />
    </div>
    <script>
      import { initTheme, toggleTheme } from '../lib/theme';
      import { initInProgressDropdown } from '../lib/inProgress';
      initTheme();
      initInProgressDropdown();
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        toggleTheme();
      });
    </script>
  </body>
</html>
