---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Works } from '../../data/works';

export async function getStaticPaths() {
  return Object.keys(Works).map((id) => ({
    params: { id },
    props: { workId: Number(id) },
  }));
}

const { workId } = Astro.props as { workId: number };
const work = Works[workId];
if (!work) {
  return Astro.redirect(import.meta.env.BASE_URL + 'works');
}
---
<BaseLayout title={`${work.title} — Heejin Chae`} current="works">
  <section class="work-wrap work-wrap--fullscreen">
    <div
      id="work"
      class="three-stage three-stage--fullscreen"
      aria-label="Three.js canvas mount"
      data-work-id={workId}
    ></div>

    <button id="info-toggle" class="info-toggle-btn" aria-label="Toggle details">i</button>

    {work.details && (
      <div id="work-details-overlay" class="work-details-overlay">
        <h2 class="work-details-overlay__title">{work.title}</h2>
        <p class="work-details-overlay__body">{work.body}</p>
        <hr class="work-details-overlay__divider" />
        <div class="work-details-overlay__content" set:html={work.details}></div>
        <small class="work-details-overlay__hint">(Press 'h' or 'i' button to toggle details)</small>
      </div>
    )}
  </section>

  {work.details && (
    <section class="work-description">
      <div class="work-description__header">
        <h1>{work.title}</h1>
        <p class="work-description__subtitle">{work.body}</p>
      </div>
      <div class="work-description__content card" set:html={work.details}></div>
    </section>
  )}
</BaseLayout>

<script>
  import * as THREE from 'three';
  import { Works } from '../../data/works';
  import { resolveThreeBgFromCss, AppConfig } from '../../config';
  import { initOverlayToggle } from '../../lib/overlayToggle';

  const mount = document.getElementById('work');
  const id = Number(mount?.dataset.workId);
  const work = Works[id];
  if (mount && work) {
    const scene = new THREE.Scene();
    const bg = resolveThreeBgFromCss() ?? AppConfig.threeBackground;
    scene.background = new THREE.Color(bg);

    let cleanup: (() => void) | null = null;
    let disposed = false;

    Promise.resolve(work.animation(scene, { mount, preview: false })).then((c) => {
      if (disposed) {
        try { c?.(); } catch { /* noop */ }
      } else {
        cleanup = c ?? null;
      }
    });

    initOverlayToggle();

    // Theme sync — update scene background on theme change while page is alive
    const onTheme = () => {
      const next = resolveThreeBgFromCss() ?? AppConfig.threeBackground;
      scene.background = new THREE.Color(next);
    };
    window.addEventListener('theme-changed', onTheme);

    // Astro produces real page navigations between routes, so cleanup runs on unload
    window.addEventListener('beforeunload', () => {
      disposed = true;
      window.removeEventListener('theme-changed', onTheme);
      try { cleanup?.(); } catch { /* noop */ }
    });
  }
</script>
